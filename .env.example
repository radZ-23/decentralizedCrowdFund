# MedTrustFund Environment Configuration
# Copy this file to .env and fill in your values

# ==================== Backend Configuration ====================

# Server
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb://127.0.0.1:27017/medtrust

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=7d

# ==================== Blockchain Configuration ====================

# RPC URL (Hardhat local or Polygon testnet)
RPC_URL=http://127.0.0.1:8545

# Private key for contract deployment (DO NOT use mainnet private key!)
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ==================== AI Service Configuration ====================

# AI Verification Service URL
AI_SERVICE_URL=http://localhost:8001

# ==================== Frontend Configuration ====================

# API URL for frontend (origin only is OK; /api is appended automatically in api.ts)
# Or use relative "/api" when the Vite dev proxy serves the backend.
VITE_API_URL=http://localhost:5000

# ==================== File Upload Configuration ====================

# Maximum file size in bytes (default: 10MB)
MAX_FILE_SIZE=10485760

# Upload directory
UPLOAD_DIR=./uploads
